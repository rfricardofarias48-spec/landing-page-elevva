
{
  "crons": [
    {
      "path": "/api/cron/admission-cleanup",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/cron/pending-sales-cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/interview-reminders",
      "schedule": "0 12 * * *"
    }
  ],
  "functions": {
    "api/**/*": {
      "maxDuration": 300
    }
  },
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "elevva.net.br" }],
      "destination": "/demonstracao",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/((?!api/|assets/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src * 'unsafe-inline' 'unsafe-eval' data: blob:; style-src * 'unsafe-inline'; script-src * 'unsafe-inline' 'unsafe-eval'; img-src * data: blob:; font-src * data:; connect-src *;"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
